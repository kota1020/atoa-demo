{
  "name": "@atoa/cli",
  "version": "0.1.0",
  "description": "AtoA — the local understanding engine. Scans your files & code so your AI employee actually knows your company. Files never leave your machine.",
  "type": "module",
  "bin": {
    "atoa": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --clean --target node20",
    "scan": "tsx src/index.ts scan",
    "serve": "tsx src/index.ts serve",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "commander": "^12.1.0",
    "ignore": "^6.0.2",
    "picocolors": "^1.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
